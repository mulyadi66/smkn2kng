#!/bin/bash

# ============================================
#  SMKN 2 Kuningan - Auto Sync to GitHub
#  Usage: ./deploy [pesan commit]
# ============================================

set -e

COMMIT_MSG="${1:-🚀 Update website $(date '+%d %m %Y %H:%M')}"

echo "🔨 Building..."
npm run build

echo "📦 Commit & Push ke main..."
git add .
if git diff --cached --quiet; then
    echo "✅ Tidak ada perubahan."
    exit 0
fi
git commit -m "$COMMIT_MSG"
git push origin main

echo "🌐 Deploy ke GitHub Pages..."
git subtree split --prefix=dist -b gh-pages --force
git push origin gh-pages --force

echo ""
echo "✅ Selesai! Website: https://mulyadi66.github.io/smkn2kng/"
